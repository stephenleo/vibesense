{
  "name": "vibesense",
  "displayName": "VibeSense",
  "description": "Controller-driven vibe coding for VSCode — haptic feedback, radial wheel prompts, idle mini-games, and gamified stats.",
  "version": "0.1.0",
  "publisher": "stephenleo",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibesense.openTerminal",
        "title": "VibeSense: Open Terminal"
      },
      {
        "command": "vibesense.launchClaudeCode",
        "title": "VibeSense: Launch Claude Code"
      },
      {
        "command": "vibesense.launchCopilotChat",
        "title": "VibeSense: Launch Copilot Chat"
      },
      {
        "command": "vibesense.voicePtt",
        "title": "VibeSense: Voice Push-to-Talk"
      },
      {
        "command": "vibesense.openQuickPanel",
        "title": "VibeSense: Open Quick Session Panel"
      },
      {
        "command": "vibesense.switchToSession",
        "title": "VibeSense: Switch to Session"
      },
      {
        "command": "vibesense.completeTutorial",
        "title": "VibeSense: Complete Tutorial (Unlock Full Mode)"
      },
      {
        "command": "vibesense.openSettings",
        "title": "VibeSense: Open Settings"
      },
      {
        "command": "vibesense.startOnboarding",
        "title": "VibeSense: Start Onboarding"
      },
      {
        "command": "vibesense.openErrorMenu",
        "title": "VibeSense: Open Error Recovery Menu"
      },
      {
        "command": "vibesense.errorRetryLastCommand",
        "title": "VibeSense: Retry Last Command"
      },
      {
        "command": "vibesense.errorClearTerminal",
        "title": "VibeSense: Clear Terminal Output"
      },
      {
        "command": "vibesense.errorViewLog",
        "title": "VibeSense: View Error Log"
      }
    ],
    "configuration": {
      "title": "VibeSense",
      "properties": {
        "vibesense.activeProfile": {
          "type": "string",
          "default": "claude-code-default",
          "description": "Name of the active binding profile. Synced via VSCode Settings Sync.",
          "order": 0
        },
        "vibesense.enableBatteryWarning": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar warning when controller battery drops below 20%.",
          "order": 1
        },
        "vibesense.fullMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable Full mode — all bindings active. When false, Guided mode restricts to core bindings (approve, deny, scroll, session switch). Full mode is also auto-unlocked when the onboarding tutorial is completed.",
          "order": 2
        },
        "vibesense.dndEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Do Not Disturb mode to suppress ambient feedback (haptic, LED, audio) below the configured priority threshold.",
          "order": 3
        },
        "vibesense.dndThreshold": {
          "type": "string",
          "enum": ["low", "normal", "high"],
          "enumDescriptions": [
            "Suppress only 'low' priority events (most feedback passes through)",
            "Suppress 'low' and 'normal' priority events (only critical/high events play)",
            "Suppress all feedback including 'normal' (only 'high' priority passes through)"
          ],
          "default": "normal",
          "description": "Priority threshold for Do Not Disturb mode. Events at or above this priority are not suppressed.",
          "order": 4
        },
        "vibesense.binding.cross": {
          "type": "string",
          "default": "vibesense.approve",
          "markdownDescription": "**✕ Cross** — DualSense face button (bottom)",
          "order": 10
        },
        "vibesense.binding.circle": {
          "type": "string",
          "default": "vibesense.deny",
          "markdownDescription": "**○ Circle** — DualSense face button (right)",
          "order": 11
        },
        "vibesense.binding.square": {
          "type": "string",
          "default": "vibesense.openTerminal",
          "markdownDescription": "**□ Square** — DualSense face button (left)",
          "order": 12
        },
        "vibesense.binding.triangle": {
          "type": "string",
          "default": "workbench.action.terminal.focus",
          "markdownDescription": "**△ Triangle** — DualSense face button (top)",
          "order": 13
        },
        "vibesense.binding.l1": {
          "type": "string",
          "default": "vibesense.switchSessionPrev",
          "markdownDescription": "**L1** — DualSense left shoulder button",
          "order": 14
        },
        "vibesense.binding.r1": {
          "type": "string",
          "default": "vibesense.switchSessionNext",
          "markdownDescription": "**R1** — DualSense right shoulder button",
          "order": 15
        },
        "vibesense.binding.l2": {
          "type": "string",
          "default": "vibesense.openRadialWheel",
          "markdownDescription": "**L2** — DualSense left trigger",
          "order": 16
        },
        "vibesense.binding.r2": {
          "type": "string",
          "default": "vibesense.openQuickPanel",
          "markdownDescription": "**R2** — DualSense right trigger",
          "order": 17
        },
        "vibesense.binding.l3": {
          "type": "string",
          "default": "",
          "markdownDescription": "**L3** — DualSense left analog stick click",
          "order": 18
        },
        "vibesense.binding.r3": {
          "type": "string",
          "default": "",
          "markdownDescription": "**R3** — DualSense right analog stick click",
          "order": 19
        },
        "vibesense.binding.up": {
          "type": "string",
          "default": "workbench.action.terminal.scrollUp",
          "markdownDescription": "**↑ D-Pad Up** — DualSense directional pad up",
          "order": 20
        },
        "vibesense.binding.down": {
          "type": "string",
          "default": "workbench.action.terminal.scrollDown",
          "markdownDescription": "**↓ D-Pad Down** — DualSense directional pad down",
          "order": 21
        },
        "vibesense.binding.left": {
          "type": "string",
          "default": "workbench.action.navigateBack",
          "markdownDescription": "**← D-Pad Left** — DualSense directional pad left",
          "order": 22
        },
        "vibesense.binding.right": {
          "type": "string",
          "default": "workbench.action.navigateForward",
          "markdownDescription": "**→ D-Pad Right** — DualSense directional pad right",
          "order": 23
        },
        "vibesense.binding.options": {
          "type": "string",
          "default": "vibesense.openSettings",
          "markdownDescription": "**Options** — DualSense options button",
          "order": 24
        },
        "vibesense.binding.touchpad": {
          "type": "string",
          "default": "vibesense.voicePtt",
          "markdownDescription": "**Touchpad** — DualSense touchpad click",
          "order": 25
        },
        "vibesense.binding.a": {
          "type": "string",
          "default": "vibesense.approve",
          "markdownDescription": "**A** — Xbox face button (bottom)",
          "order": 30
        },
        "vibesense.binding.b": {
          "type": "string",
          "default": "vibesense.deny",
          "markdownDescription": "**B** — Xbox face button (right)",
          "order": 31
        },
        "vibesense.binding.x": {
          "type": "string",
          "default": "vibesense.openTerminal",
          "markdownDescription": "**X** — Xbox face button (left)",
          "order": 32
        },
        "vibesense.binding.y": {
          "type": "string",
          "default": "workbench.action.terminal.focus",
          "markdownDescription": "**Y** — Xbox face button (top)",
          "order": 33
        },
        "vibesense.binding.lb": {
          "type": "string",
          "default": "vibesense.switchSessionPrev",
          "markdownDescription": "**LB** — Xbox left bumper",
          "order": 34
        },
        "vibesense.binding.rb": {
          "type": "string",
          "default": "vibesense.switchSessionNext",
          "markdownDescription": "**RB** — Xbox right bumper",
          "order": 35
        },
        "vibesense.binding.lt": {
          "type": "string",
          "default": "vibesense.openRadialWheel",
          "markdownDescription": "**LT** — Xbox left trigger",
          "order": 36
        },
        "vibesense.binding.rt": {
          "type": "string",
          "default": "vibesense.openQuickPanel",
          "markdownDescription": "**RT** — Xbox right trigger",
          "order": 37
        },
        "vibesense.binding.ls": {
          "type": "string",
          "default": "",
          "markdownDescription": "**LS** — Xbox left analog stick click",
          "order": 38
        },
        "vibesense.binding.rs": {
          "type": "string",
          "default": "",
          "markdownDescription": "**RS** — Xbox right analog stick click",
          "order": 39
        },
        "vibesense.binding.menu": {
          "type": "string",
          "default": "vibesense.openSettings",
          "markdownDescription": "**Menu** — Xbox menu button",
          "order": 40
        },
        "vibesense.binding.view": {
          "type": "string",
          "default": "vibesense.voicePtt",
          "markdownDescription": "**View** — Xbox view button",
          "order": 41
        }
      }
    }
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src --ext ts,tsx",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.webview.json",
    "package": "vsce package",
    "vscode:prepublish": "npm run build",
    "postinstall": "electron-rebuild -f -w node-hid",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "node ./out/test/integration/runTests.js"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "css-loader": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-import": "^2.28.0",
    "jsdom": "^29.0.1",
    "mocha": "^11.7.5",
    "prebuild-install": "^7.1.3",
    "style-loader": "^3.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "dualsense-ts": "^5.5.0",
    "node-hid": "^3.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zod": "^4.3.6"
  }
}
