# .vscodeignore
# Files excluded from the VSIX package

# Source files — only dist/ is needed
src/
test/
scripts/

# Config and tooling files
.eslintrc.json
.prettierrc
tsconfig*.json
webpack.config.js
.github/

# Build tooling devDependencies — exclude from VSIX (not needed at runtime)
# Note: vsce automatically excludes packages listed in devDependencies from the VSIX.
# Do NOT add node_modules/ here — runtime dependencies (node-hid, dualsense-ts, react)
# must be present in the VSIX. Only devDependency tool folders are listed below.
node_modules/@electron/rebuild/
node_modules/prebuild-install/

# TypeScript source maps (nosources mode used)
**/*.ts
**/*.tsx
**/*.map

# Raw native binary files — platform-specific binaries bundled via
# `vsce package --target <platform>` in Story 1.4
**/*.node
**/*.dylib
**/*.so
**/*.dll

# Development files
.vscode/
*.vsix
*.log

# Keep these in the package:
# dist/
# resources/
# profiles/
# package.json
# LICENSE
